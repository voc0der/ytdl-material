{
  "name": "ytdl-material",
  "version": "4.3.2",
  "license": "MIT",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "codespaces": "ng serve --configuration=codespaces",
    "build": "ng build --configuration production",
    "prebuild": "node src/postbuild.mjs",
    "heroku-postbuild": "npm install --prefix backend",
    "test": "ng test --browsers Chromium",
    "test:headless": "ng test --watch=false --browsers ChromiumHeadless",
    "lint": "eslint --ext .ts,.js src",
    "electron": "ng build --base-href ./ && electron .",
    "generate": "openapi --input ./\"Public API v1.yaml\" --output ./src/api-types --exportCore false --exportServices false --exportModels true",
    "i18n-source": "ng extract-i18n --output-path=src/assets/i18n --out-file=messages.en.xlf"
  },
  "engines": {
    "node": ">=24 <26",
    "npm": ">=10"
  },
  "private": true,
  "dependencies": {
    "@angular-devkit/core": "^21.2.3",
    "@angular/animations": "^21.2.5",
    "@angular/cdk": "^21.2.3",
    "@angular/common": "^21.2.5",
    "@angular/compiler": "^21.2.5",
    "@angular/core": "^21.2.5",
    "@angular/forms": "^21.2.5",
    "@angular/localize": "^21.2.5",
    "@angular/material": "^21.2.3",
    "@angular/platform-browser": "^21.2.5",
    "@angular/platform-browser-dynamic": "^21.2.5",
    "@angular/router": "^21.2.5",
    "@fontsource/material-icons": "^5.2.7",
    "@ngneat/content-loader": "^7.0.0",
    "@videogular/ngx-videogular": "^20.0.0",
    "core-js": "^3.49.0",
    "crypto-js": "^4.2.0",
    "file-saver": "^2.0.2",
    "filesize": "^11.0.13",
    "fs-extra": "^11.3.4",
    "material-icons": "^1.10.8",
    "nan": "^2.26.1",
    "ngx-avatars": "1.10.1",
    "ngx-file-drop": "^16.0.0",
    "rxjs": "^7.8.2",
    "tslib": "^2.0.0",
    "typescript": "~5.9.3",
    "xliff-to-json": "^1.0.4",
    "zone.js": "~0.16.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.3",
    "@angular/cli": "^21.2.3",
    "@angular/compiler-cli": "^21.2.5",
    "@angular/language-service": "^21.2.5",
    "@eslint/js": "^10.0.1",
    "@types/core-js": "^2.5.2",
    "@types/file-saver": "^2.0.1",
    "@types/jasmine": "^6.0.0",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "ajv": "^8.18.0",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "jasmine-core": "~6.1.0",
    "jasmine-spec-reporter": "~7.0.0",
    "karma": "~6.4.2",
    "karma-chrome-launcher": "~3.2.0",
    "karma-cli": "~2.0.0",
    "karma-coverage-istanbul-reporter": "~3.0.2",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "2.2.0",
    "openapi-typescript-codegen": "^0.30.0",
    "ts-node": "~10.9.2"
  },
  "overrides": {
    "@angular-devkit/core": {
      "ajv": "8.18.0"
    },
    "express-rate-limit": "8.3.1",
    "ngx-avatars": {
      "@angular/common": "21.2.0",
      "@angular/core": "21.2.0"
    },
    "flatted": "3.4.1",
    "immutable": "5.1.5",
    "serialize-javascript": "7.0.3",
    "tar": "7.5.11",
    "tmp": "0.2.5",
    "undici": "7.24.2"
  }
