{
  "name": "ytdl-material",
  "version": "1.0.7",
  "license": "MIT",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "codespaces": "ng serve --configuration=codespaces",
    "build": "ng build --configuration production",
    "prebuild": "node src/postbuild.mjs",
    "heroku-postbuild": "npm install --prefix backend",
    "test": "ng test --browsers Chromium",
    "test:headless": "ng test --watch=false --browsers ChromiumHeadless",
    "lint": "eslint --ext .ts,.js src",
    "electron": "ng build --base-href ./ && electron .",
    "generate": "openapi --input ./\"Public API v1.yaml\" --output ./src/api-types --exportCore false --exportServices false --exportModels true",
    "i18n-source": "ng extract-i18n --output-path=src/assets/i18n --out-file=messages.en.xlf"
  },
  "engines": {
    "node": ">=24 <26",
    "npm": ">=10"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^22.0.5",
    "@angular/cdk": "^22.0.4",
    "@angular/common": "^22.0.5",
    "@angular/compiler": "^22.0.5",
    "@angular/core": "^22.0.5",
    "@angular/forms": "^22.0.5",
    "@angular/localize": "^22.0.5",
    "@angular/material": "^22.0.4",
    "@angular/platform-browser": "^22.0.5",
    "@angular/platform-browser-dynamic": "^22.0.5",
    "@angular/router": "^22.0.5",
    "@fontsource/material-icons": "^5.2.7",
    "@ngneat/content-loader": "^7.0.0",
    "@videogular/ngx-videogular": "^20.0.0",
    "core-js": "^3.49.0",
    "crypto-js": "^4.2.0",
    "file-saver": "^2.0.2",
    "filesize": "^11.0.19",
    "fs-extra": "^11.3.6",
    "material-icons": "^1.10.8",
    "nan": "^2.28.0",
    "ngx-avatars": "1.10.2",
    "ngx-file-drop": "^16.0.0",
    "rxjs": "^7.8.2",
    "tslib": "^2.0.0",
    "typescript": "~7.0.2",
    "xliff-to-json": "^1.0.4",
    "zone.js": "~0.16.2"
  },
  "devDependencies": {
    "@angular-devkit/core": "^22.0.5",
    "@angular/build": "^22.0.5",
    "@angular/cli": "^22.0.5",
    "@angular/compiler-cli": "^22.0.5",
    "@angular/language-service": "^22.0.5",
    "@eslint/js": "^10.0.1",
    "@types/core-js": "^2.5.2",
    "@types/file-saver": "^2.0.1",
    "@types/jasmine": "^6.0.0",
    "@types/node": "^26.1.1",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "ajv": "^8.20.0",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "istanbul-lib-instrument": "^6.0.3",
    "jasmine-core": "~6.3.0",
    "jasmine-spec-reporter": "~7.0.0",
    "karma": "~6.4.2",
    "karma-chrome-launcher": "~3.2.0",
    "karma-cli": "~2.0.0",
    "karma-coverage-istanbul-reporter": "~3.0.2",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "2.2.0",
    "openapi-typescript-codegen": "^0.31.0",
    "ts-node": "~10.9.2"
  },
  "overrides": {
    "@babel/core": "7.29.6",
    "@angular/build": {
      "picomatch": "4.0.4"
    },
    "@angular-devkit/build-angular": {
      "picomatch": "4.0.4",
      "http-proxy-middleware": {
        "micromatch": {
          "picomatch": "2.3.2"
        }
      },
      "webpack-dev-server": {
        ".": "5.2.4",
        "chokidar": {
          "anymatch": {
            "picomatch": "2.3.2"
          },
          "readdirp": {
            "picomatch": "2.3.2"
          }
        }
      }
    },
    "@angular-devkit/core": {
      "ajv": "8.18.0",
      "picomatch": "4.0.4"
    },
    "esbuild": "0.28.1",
    "express-rate-limit": "8.5.1",
    "ngx-avatars": {
      "@angular/common": "21.2.0",
      "@angular/core": "21.2.0"
    },
    "flatted": "3.4.2",
    "hono": "4.12.25",
    "immutable": "5.1.5",
    "js-yaml": "4.2.0",
    "postcss": "8.5.12",
    "serialize-javascript": "7.0.5",
    "tar": "7.5.16",
    "tmp": "0.2.7",
    "undici": "7.28.0",
    "uuid": "14.0.0",
    "vite": "7.3.5",
    "ws": "8.21.0"
  }
