{
  "name": "ytdl-material",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "..",
    "args": {
      "NODE_VERSION": "24"
    }
  },
  "forwardPorts": [4200, 17442],
  "portsAttributes": {
    "4200": {
      "label": "Angular dev server"
    },
    "17442": {
      "label": "ytdl-material backend",
      "onAutoForward": "openBrowser"
    }
  },
  "postCreateCommand": "npm ci && npm ci --prefix backend",
  "customizations": {
    "vscode": {
      "extensions": [
        "angular.ng-template",
        "dbaeumer.vscode-eslint",
        "42crunch.vscode-openapi",
        "christian-kohler.npm-intellisense",
        "redhat.vscode-yaml",
        "github.vscode-pull-request-github",
        "DavidAnson.vscode-markdownlint"
      ]
    }
  }
}
