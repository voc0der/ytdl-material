{
    "manifest_version": 2,
    "name": "ytdl-material",
    "version": "0.4",
    "description": "The Official Firefox & Chrome Extension of ytdl-material, an open-source and self-hosted YouTube downloader.",
    "icons": {
        "16": "icons/icon-16.png",
        "32": "icons/icon-32.png",
        "48": "icons/icon-48.png",
        "64": "icons/icon-64.png",
        "128": "icons/icon-128.png"
    },
    "background": {
        "scripts": [
            "background.js"
        ],
        "persistent": false
    },
    "browser_action": {
        "default_icon": {
            "16": "icons/icon-16.png",
            "32": "icons/icon-32.png",
            "48": "icons/icon-48.png",
            "64": "icons/icon-64.png",
            "128": "icons/icon-128.png"
        },
        "default_popup": "popup.html",
        "default_title": "ytdl-material"
    },
    "permissions": [
        "tabs",
        "storage",
        "contextMenus"
    ],
    "options_ui": {
        "page": "options.html",
        "open_in_tab": false
    },
    "browser_specific_settings": {
        "gecko": {
          "id": "IsaacMGrynsztein@gmail.com",
          "strict_min_version": "57.0"
        }
    }
}
