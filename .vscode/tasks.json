{
  "version": "2.0.0",
  "windows": {
    "options": {
      "shell": {
        "executable": "cmd.exe",
        "args": [
          "/d",
          "/c"
        ]
      }
    }
  },
  "tasks": [
    {
      "label": "Dev: install dependencies",
      "type": "shell",
      "command": "npm ci && npm ci --prefix backend",
      "problemMatcher": []
    },
    {
      "type": "npm",
      "script": "start",
      "problemMatcher": [],
      "label": "Dev: start frontend",
      "detail": "ng serve",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      }
    },
    {
      "type": "npm",
      "script": "build",
      "problemMatcher": [],
      "label": "Dev: build frontend for backend",
      "detail": "ng build --configuration production",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      }
    },
    {
      "label": "Dev: start backend",
      "type": "shell",
      "command": "node app.js",
      "options": {
        "cwd": "${workspaceFolder}/backend",
        "env": {
          "YTDL_MODE": "debug"
        }
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      },
      "problemMatcher": []
    },
    {
      "label": "Dev: run full stack",
      "dependsOn": [
        "Dev: start backend",
        "Dev: start frontend"
      ],
      "dependsOrder": "parallel"
    }
  ]
}
