{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Dev: Debug Backend",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/backend/app.js",
      "cwd": "${workspaceFolder}/backend",
      "env": {
        "YTDL_MODE": "debug"
      },
      "console": "integratedTerminal",
      "skipFiles": [
        "<node_internals>/**"
      ]
    },
    {
      "name": "Dev: Attach Backend",
      "type": "node",
      "request": "attach",
      "port": 9229,
      "restart": true
    },
    {
      "name": "Dev: Launch Frontend (Edge)",
      "type": "msedge",
      "request": "launch",
      "url": "http://localhost:4200",
      "webRoot": "${workspaceFolder}"
    }
  ]
}
